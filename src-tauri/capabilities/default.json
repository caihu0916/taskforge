{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for TaskForge Desktop — FRONT-004 最小化：移除 shell:allow-spawn/execute/kill 与 fs:allow-* 通配权限，sidecar 改由 Rust 侧启动；fs 访问通过 fs:scope 限定范围，前端如需文件操作走 Rust command。",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "process:default",
    "process:allow-restart",
    "process:allow-exit",
    "clipboard-manager:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "fs:scope",
    "os:default",
    "os:allow-os-type",
    "os:allow-platform",
    "os:allow-version",
    "os:allow-hostname",
    "os:allow-arch",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "updater:default"
  ]
}
