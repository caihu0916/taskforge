# TaskForge Environment Configuration
# Copy this file to .env and fill in your values

# === Server ===
TF_SERVER__HOST=0.0.0.0
TF_SERVER__PORT=8001

# === LLM Configuration ===
# Option A: Local Ollama (free, recommended)
# Install: https://ollama.com/download
# Ollama runs on localhost:11434 by default — no config needed

# Option B: Remote SaaS API
# TF_LLM__API_KEY=your-api-key-here
# TF_LLM__BASE_URL=https://api.openai.com/v1
# TF_LLM__MODEL=gpt-4o-mini

# === Database ===
# SQLite (default, zero-config)
TF_DATABASE__URL=sqlite:///taskforge.db

# === Security ===
# Generate a secure random string: python -c "import secrets; print(secrets.token_hex(32))"
TF_SECURITY__JWT_SECRET=change-me-to-a-random-secret

# === Frontend ===
# The frontend dev server runs on port 3000
# VITE_API_BASE_URL is set automatically
